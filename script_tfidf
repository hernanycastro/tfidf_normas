}

processar_ano_historico <- function(ano, url_pdf) {
  arquivo_rds <- paste0("projeto_legislativo/processados/historico_", ano, ".rds")
  if (file_exists(arquivo_rds)) return(NULL)
  
  message(paste(">>> Processando Documento Histórico - Ano:", ano))
  tryCatch({
    # Como o Planalto usa páginas HTML em vez de PDFs diretos para Atos, capturamos o texto do HTML
    html <- read_html(url_pdf)
    texto_bruto <- html %>% html_text()
    
    if (str_detect(texto_bruto, regex_consolidada)) {
      dados_historicos <- tibble(
        id = paste0("HIST-", ano),
        dataApresentacao = as.Date(paste0(ano, "-01-01")), 
        ano_base = ano,
        txtEmenta = str_sub(str_squish(texto_bruto), 1, 1000), 
        flag_idoso = str_detect(texto_bruto, regex_idoso),
        flag_defic = str_detect(texto_bruto, regex_defic),
        flag_rua   = str_detect(texto_bruto, regex_rua),
        periodo    = ifelse(ano < 1889, "Império", "República Velha")
      )
      write_rds(dados_historicos, arquivo_rds)
    }
  }, error = function(e) {
    log_erro(ano, paste("Erro histórico:", e$message))
  })
}

processar_ano_moderno <- function(ano) {
  arquivo_rds <- paste0("projeto_legislativo/processados/moderno_", ano, ".rds")
  if (file_exists(arquivo_rds)) return(NULL)
  
  message(paste(">>> Minerando dados da API da Câmara - Ano:", ano))
  tryCatch({
    url_fonte <- paste0("https://dadosabertos.camara.leg.br/arquivos/proposicoes/csv/proposicoes-", ano, ".csv")
    arquivo_csv <- paste0("projeto_legislativo/brutos/modernos/prop_", ano, ".csv")
    
    request(url_fonte) %>% req_perform(path = arquivo_csv)
    
    dados_brutos <- read_delim(arquivo_csv, delim = ";", show_col_types = FALSE, guess_max = 1000)
    colnames(dados_brutos) <- str_to_lower(colnames(dados_brutos))
    
    # PROTEÇÃO CONTRA COLUNAS FANTASMAS (Fora do mutate)
    if (!"id" %in% names(dados_brutos)) dados_brutos$id <- NA_character_
    if (!"txtementa" %in% names(dados_brutos) & "ementa" %in% names(dados_brutos)) dados_brutos$txtementa <- dados_brutos$ementa
    if (!"txtementa" %in% names(dados_brutos)) dados_brutos$txtementa <- NA_character_
    if (!"dataapresentacao" %in% names(dados_brutos) & "datainclusao" %in% names(dados_brutos)) dados_brutos$dataapresentacao <- dados_brutos$datainclusao
    if (!"dataapresentacao" %in% names(dados_brutos)) dados_brutos$dataapresentacao <- NA_character_
    
    dados_ano <- dados_brutos %>% 
      mutate(
        texto_limpo = coalesce(as.character(txtementa), NA_character_)
      ) %>% 
      filter(!is.na(texto_limpo)) %>% 
      filter(str_detect(texto_limpo, regex_consolidada)) %>% 
      mutate(
        id_final = coalesce(as.character(id), as.character(row_number())),
        # Conversão segura de data
        data_final = tryCatch(as.Date(dataapresentacao), error = function(e) as.Date(paste0(ano, "-01-01"))),
        dataApresentacao = coalesce(data_final, as.Date(paste0(ano, "-01-01"))),
        txtEmenta = texto_limpo,
        ano_base = ano,
        flag_idoso = str_detect(txtEmenta, regex_idoso),
        flag_defic = str_detect(txtEmenta, regex_defic),
        flag_rua   = str_detect(txtEmenta, regex_rua),
        periodo    = "Republicano Moderno"
      ) %>% 
      select(id = id_final, dataApresentacao, txtEmenta, ano_base, flag_idoso, flag_defic, flag_rua, periodo)
    
    write_rds(dados_ano, arquivo_rds)
    if (file_exists(arquivo_csv)) file_delete(arquivo_csv)
    Sys.sleep(runif(1, 0.2, 0.8)) 
    
  }, error = function(e) {
    log_erro(ano, paste("Falha na estrutura interna:", e$message))
    if (file_exists(arquivo_csv)) file_delete(arquivo_csv)
  })
}

