log_erro <- function(ano, mensagem) {
  write(paste(now(), "| Ano:", ano, "| Erro:", mensagem), 
        file = "projeto_legislativo/log_erros.txt", append = TRUE)
}

regex_idoso <- "(?i)idoso|idosa|velhice|terceira idade|anciã|asilo de inválido|decrepitude|ancianidade|asilo de velhos"
regex_defic <- "(?i)deficiênc|defeito físico|defeito physico|inválido|invalidez|incapaz|excepciona|mutilado|surdo-mudo|cego|alienado|invalidos da patria"
regex_rua   <- "(?i)situação de rua|população de rua|morador de rua|mendig|vadiag|vadi|indigent|sem domicilio|sem tecto|vabund|mendicidade|casa de detensão"
regex_consolidada <- paste(regex_idoso, regex_defic, regex_rua, sep = "|")

