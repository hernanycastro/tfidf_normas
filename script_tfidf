library(tidyverse)

df_analise <- read_csv("projeto_legislativo/corpus_consolidado_1850_2026.csv", show_col_types = FALSE)

# Transforma os dados para o formato longo (tidy) e limpa ruídos temporais
df_timeline <- df_analise %>%
  # FILTRO DE SEGURANÇA: Garante apenas o escopo real do seu projeto
  filter(ano_base >= 1850 & ano_base <= 2026) %>% 
  pivot_longer(
    cols = c(flag_idoso, flag_defic, flag_rua),
    names_to = "Grupo_Social",
    values_to = "Ocorrencia"
  ) %>%
  filter(Ocorrencia == TRUE) %>%
  mutate(
    Grupo_Social = case_when(
      Grupo_Social == "flag_idoso" ~ "Idosos",
      Grupo_Social == "flag_defic" ~ "Pessoas com Deficiência",
      Grupo_Social == "flag_rua"   ~ "Situação de Rua"
    )
  ) %>%
  count(ano_base, Grupo_Social)

# Plota o gráfico longitudinal corrigido
ggplot(df_timeline, aes(x = ano_base, y = n, color = Grupo_Social, group = Grupo_Social)) +
  # Corrigido de size para linewidth para eliminar a mensagem de aviso
  geom_line(linewidth = 1.2, alpha = 0.8) +
  geom_point(size = 1.5, alpha = 0.5) +
  scale_color_viridis_d(option = "plasma") +
  # Quebra o eixo X de 20 em 20 anos para ficar mais legível
  scale_x_continuous(breaks = seq(1850, 2026, by = 20)) + 
  labs(
    title = "Evolução Temporal da Produção Legislativa por Grupo Social",
    subtitle = "Análise longitudinal baseada em ementas federais (1850 - 2026)",
    x = "Ano",
    y = "Número de Atos Normativos",
    color = "Grupo Vulnerável"
  ) +
  theme_minimal(base_size = 12) +
  theme(
    legend.position = "bottom",
    panel.grid.minor = element_blank(),
    plot.title = element_text(face = "bold", size = 14),
    axis.text.x = element_text(angle = 45, hjust = 1) # Inclina os anos para não encavalarem
  )

# ==============================================================================
# PIPELINE DE TF-IDF NORMALIZADO: EQUILÍBRIO DE PESO HISTÓRICO (1930 - 2026)
# ==============================================================================
library(tidyverse)
library(tidytext)

# 1. Carregar a base de dados
df_analise <- read_csv("projeto_legislativo/corpus_consolidado_1850_2026.csv", show_col_types = FALSE) %>% 
  filter(ano_base >= 1930 & ano_base <= 2026)

# 2. Estratégia de Normalização: Concatenar todo o texto por década antes da contagem
df_super_documentos <- df_analise %>%
  mutate(decada = paste0((ano_base %/% 10) * 10, "s")) %>% 
  group_by(decada) %>% 
  summarise(texto_consolidado = paste(txtEmenta, collapse = " "), .groups = "drop")

# 3. Tokenização e Limpeza do Super Corpus (CORRIGIDO: %in% ajustado)
palavras_normalizadas <- df_super_documentos %>%
  unnest_tokens(palavra, texto_consolidado) %>% 
  filter(!str_detect(palavra, "\\d+")) %>% 
  filter(!palavra %in% tidytext::get_stopwords(language = "pt")$word) %>% 
  filter(!palavra %in% c("lei", "art", "decreto", "nº", "público", "pública", "dispõe", 
                         "providências", "altera", "nacional", "federal", "sobre", "daí", 
                         "atividades", "geral", "efeitos", "outras", "capital", "republica"))

# 4. Contagem de Termos 
contagem_normalizada <- palavras_normalizadas %>%
  count(decada, palavra, sort = TRUE)

# 5. Cálculo do TF-IDF sobre a estrutura equilibrada de 10 décadas
tf_idf_equilibrado <- contagem_normalizada %>%
  bind_tf_idf(palavra, decada, n) %>% 
  arrange(decada, desc(tf_idf))

# 6. Selecionar o Top 5 de TODAS as décadas de 1930 a 2020 (Sem empates)
top_termos_historicos <- tf_idf_equilibrado %>%
  filter(decada %in% c("1930s", "1940s", "1950s", "1960s", "1970s", "1980s", "1990s", "2000s", "2010s", "2020s")) %>% 
  group_by(decada) %>%
  slice_max(tf_idf, n = 5, with_ties = FALSE) %>%
  ungroup()

# 7. Plotagem Espaçada em Painéis Expandidos (Atribuído à variável 'p')
p <- ggplot(top_termos_historicos, aes(x = tf_idf, y = reorder_within(palavra, tf_idf, decada), fill = decada)) +
  geom_col(show.legend = FALSE, width = 0.7) +
  scale_y_reordered() +
  facet_wrap(~decada, scales = "free_y", ncol = 2) + 
  scale_fill_viridis_d(option = "turbo", begin = 0.1, end = 0.9) +
  labs(
    title = "Top 5 Palavras-Chave por Década (TF-IDF Normalizado)",
    subtitle = "Pesos corrigidos proporcionalmente para neutralizar o viés volumétrico do presente",
    x = "Importância Relativa Corrigida (Peso TF-IDF)",
    y = "Termos do Vocabulário Político-Jurídico"
  ) +
  theme_minimal(base_size = 11) +
  theme(
    plot.title = element_text(face = "bold", size = 13),
    panel.grid.major.y = element_blank(),
    panel.grid.minor = element_blank(),
    strip.text = element_text(face = "bold", size = 10, color = "navy")
  )

